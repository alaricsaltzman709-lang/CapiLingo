rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Explicit get-check for administrative privileges
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Entity validator function for User
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'passwordHash', 'name', 'role']) &&
             data.keys().size() == 5 &&
             data.id is string && data.id.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.passwordHash is string && data.passwordHash.size() <= 256 &&
             data.name is string && data.name.size() <= 128 &&
             data.role is string && (data.role == 'student' || data.role == 'admin');
    }

    // Entity validator function for Module
    function isValidModule(data) {
      return data.keys().hasAll(['id', 'level', 'title', 'description']) &&
             data.id is string && data.id.size() <= 128 &&
             data.level is string && (data.level == 'basico' || data.level == 'intermedio' || data.level == 'avanzado') &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000;
    }

    // Entity validator function for StudentProgress
    function isValidProgress(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'level', 'exp', 'completedLessons']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.level is string && (data.level == 'basico' || data.level == 'intermedio' || data.level == 'avanzado') &&
             data.exp is number && data.exp >= 0 &&
             data.completedLessons is list;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidId(userId) && isValidUser(request.resource.data);
      allow delete: if true;
    }

    // Modules Collection rules
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if isValidId(moduleId) && isValidModule(request.resource.data);
    }

    // Student Progress Collection rules
    match /progress/{userId} {
      allow read, list: if true;
      allow create, update: if isValidId(userId) && isValidProgress(request.resource.data);
      allow delete: if true;
    }
  }
}
